{
  "permissions": {
    "allow": [
      "Read(**/*)",
      "Read(~/.claude/review-rubrics/**)",
      "Write(.review-*)"
    ],
    "deny": [
      "Write(**/secret.json)",
      "Write(**/.env*)",
      "Write(~/.ssh/**)",
      "Write(~/.gitee_token)",
      "Write(**/.git/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/credentials*)",
      "Write(**/id_rsa*)"
    ]
  }
}
